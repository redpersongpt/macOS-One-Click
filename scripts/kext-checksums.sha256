# SHA-256 checksums for embedded kext ZIPs.
# These MUST be updated whenever kext versions change.
# To regenerate after a trusted download:
#   shasum -a 256 /path/to/downloaded.zip
# Then paste the hash below next to the matching repo key.
#
# Format: <sha256-hash>  <repo-key>
# The repo key is the GitHub "owner/repo" with '/' replaced by '_'.

PLACEHOLDER_HASH_UPDATE_ME  acidanthera_Lilu
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_VirtualSMC
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_WhateverGreen
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_AppleALC
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_RTCMemoryFixup
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_VoodooPS2
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_RestrictEvents
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_NVMeFix
PLACEHOLDER_HASH_UPDATE_ME  acidanthera_CPUTopologyRebuild
